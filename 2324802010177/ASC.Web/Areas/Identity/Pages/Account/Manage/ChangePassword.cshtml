@page
@model ASC.Web.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_SecureLayout.cshtml";
}

<div class="row">
    <div class="col s12">
        <h4 class="brown-text"><i class="material-icons left">lock</i>Đổi mật khẩu</h4>
    </div>
</div>

@if (Model.StatusMessage != null)
{
    <div class="row"><div class="col s12">
        <div class="card-panel green lighten-4 green-text text-darken-2 auto-dismiss">
            <i class="material-icons tiny">check_circle</i> @Model.StatusMessage
        </div>
    </div></div>
}

<div class="row">
    <div class="col s12 m6 offset-m3">
        <div class="card">
            <div class="card-content">
                <form method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="card-panel red lighten-4 red-text"></div>

                    <div class="input-field">
                        <i class="material-icons prefix">lock_outline</i>
                        <input asp-for="Input.OldPassword" type="password" id="oldPwd" class="validate" />
                        <label asp-for="Input.OldPassword" for="oldPwd">Mật khẩu hiện tại</label>
                        <span asp-validation-for="Input.OldPassword" class="helper-text red-text"></span>
                    </div>

                    <div class="input-field">
                        <i class="material-icons prefix">lock</i>
                        <input asp-for="Input.NewPassword" type="password" id="newPwd" class="validate" />
                        <label asp-for="Input.NewPassword" for="newPwd">Mật khẩu mới (ít nhất 6 ký tự + 1 số)</label>
                        <span asp-validation-for="Input.NewPassword" class="helper-text red-text"></span>
                    </div>

                    <div class="input-field">
                        <i class="material-icons prefix">lock</i>
                        <input asp-for="Input.ConfirmPassword" type="password" id="confPwd" class="validate" />
                        <label asp-for="Input.ConfirmPassword" for="confPwd">Xác nhận mật khẩu mới</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="helper-text red-text"></span>
                    </div>

                    <div style="margin-top:20px">
                        <button type="submit" class="btn brown darken-2 waves-effect">
                            <i class="material-icons left">save</i>Lưu mật khẩu mới
                        </button>
                        <a href="/ServiceRequests/Dashboard/Dashboard" class="btn-flat" style="margin-left:8px">
                            Huỷ
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <div class="card-panel blue lighten-5">
            <strong>Yêu cầu mật khẩu:</strong>
            <ul style="margin:5px 0 0 15px;font-size:13px">
                <li>Ít nhất 6 ký tự</li>
                <li>Phải có ít nhất 1 chữ số (0-9)</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
